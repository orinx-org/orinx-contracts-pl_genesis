# Private key for deployment (generate a fresh wallet: npx hardhat generate-wallet)
PRIVATE_KEY=your_private_key_here

# RPC URLs
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# API Keys
ETHERSCAN_API_KEY=your_etherscan_api_key

# Optional: Existing underlying token address for ZamaShieldedToken
# If not set, a MockERC20 will be deployed for testing
# SEPOLIA_UNDERLYING_TOKEN=0x...

# Optional: Configure announcer fee settings
# FEE_RECEIVER=0x...  # Address to receive protocol fees
# FEE_BPS=100         # Fee in basis points (100 = 1%, max 500 = 5%)
